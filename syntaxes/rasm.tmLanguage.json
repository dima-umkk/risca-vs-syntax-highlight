{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "RiscA Assembler",
	"patterns": [
		{"include": "#labels"},
		{"include": "#jump_targets_cond"},
		{"include": "#jump_targets_djnz"},
		{"include": "#jump_targets_simple"},
		{"include": "#instructions"},
		{"include": "#directives"},
		{"include": "#const_definitions"},
		{"include": "#const_usage_dollar"},
		{"include": "#comments"},
		{"include": "#keywords"},
		{"include": "#strings"},
		{"include": "#registers"},
		{"include": "#numbers"},
		{"include": "#variables"}
	],
	"repository": {
	    "labels": {
			"match": "^[a-zA-Z_][a-zA-Z0-9_]*:",
			"name": "entity.name.function.rasm"
	    },
		"jump_targets_simple": {
			"match": "(?i)\\b(jmp|call|djnz)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
			"captures": {
				"1": { "name": "keyword.control.instruction.rasm" },
				"2": { "name": "entity.name.function.rasm" }
			}
		},
		"jump_targets_djnz": {
			"match": "(?i)\\b(djnz)\\b\\s+(r\\d+)\\s*,\\s*([A-Za-z_][A-Za-z0-9_]*)\\b",
			"captures": {
				"1": { "name": "keyword.control.instruction.rasm" },
				"2": { "name": "variable.language.register.rasm" },
				"3": { "name": "entity.name.function.rasm" }
			}
		},
		"jump_targets_cond": {
			"match": "(?i)\\b(jmp)\\b\\s+(r\\d+)\\s*(==|!=|<=|>=|<|>)\\s*(r\\d+)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
			"captures": {
				"1": { "name": "keyword.control.instruction.myasm" },
				"2": { "name": "variable.language.register.myasm" },
				"3": { "name": "keyword.operator.comparison.myasm" },
				"4": { "name": "variable.language.register.myasm" },
				"5": { "name": "entity.name.function.rasm" }
			}
		},
		"instructions": {
			"match": "(?i)\\b(ld\\.0|ld\\.b|ld\\.w|ld\\.d|ldi|st\\.b|st\\.w|st\\.d|add|sub|jmp|call|ret|push|pop|xor|and|or|not|djnz|shl|shr)\\b",
			"name": "keyword.control.instruction.rasm"
		},
		"directives": {
			"match": "(?i)\\b(org|db|dw|dd|include)\\b",
			"name": "keyword.other.directive"
	    },
		"const_definitions": {
			"match": "(?i)\\b([A-Za-z_][A-Za-z0-9_]*)\\s+(equ)\\b",
			"captures": {
				"1": { "name": "variable.other.constant.rasm" },
				"2": { "name": "keyword.other.directive.rasm" }
			}
		},
		"const_usage_dollar": {
			"match": "\\$([A-Za-z_][A-Za-z0-9_]*)",
			"captures": {
				"1": { "name": "variable.other.constant.rasm" }
			}
		},
		"comments": {
			"begin": ";",
			"end": "$",
			"name": "comment.line.semicolon.rasm"
		},
		"strings": {
			"name": "string.quoted.single.rasm",
			"begin": "'",
			"end": "'",
			"patterns": [
				{
					"name": "constant.character.escape.rasm",
					"match": "\\\\."
				}
			]
		},
	    "registers": {
    		"match": "(?i)\\b(r0|r1|r2|r3|r4|r5|r6|r7|r8|r9|r10|r11|r12|r13|r14|r15|sp|lr)\\b",
      		"name": "variable.language.register.rasm"
    	},
		"numbers": {
			"match": "\\b(0x[0-9a-fA-F]+|0b[01]+|[0-9]+)\\b",
			"name": "constant.numeric.rasm"
	    },
	    "variables": {
			"match": "\\b\\$?[A-Za-z_][A-Za-z0-9_]*\\b",
			"name": "variable.other.myasm"
    	}
	},
	"scopeName": "source.rasm"
}